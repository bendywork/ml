    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"from sklearn.preprocessing import PolynomialFeatures\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": 2,\n",
    "   \"id\": \"258705e3\",\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [\n",
    "    {\n",
    "     \"name\": \"stdout\",\n",
    "     \"output_type\": \"stream\",\n",
    "     \"text\": [\n",
    "      \"[[ 1.  2.  3.  2.  3.  6.  6.]\\n\",\n",
    "      \" [ 2.  3.  4.  6.  8. 12. 24.]]\\n\"\n",
    "     ]\n",
    "    }\n",
    "   ],\n",
    "   \"source\": [\n",
    "    \"poly = PolynomialFeatures(degree=3,\\n\",\n",
    "    \"                          include_bias=False,\\n\",\n",
    "    \"                          interaction_only=True)\\n\",\n",
    "    \"\\\"\\\"\\\"\\n\",\n",
    "    \"degree：扩展的阶数\\n\",\n",
    "    \"interaction_only： 是否只保留交互项\\n\",\n",
    "    \"include_bias：是否包含偏置项\\n\",\n",
    "    \"\\\"\\\"\\\"\\n\",\n",
    "    \"x = [[1, 2, 3],\\n\",\n",
    "    \"     [2, 3, 4]]\\n\",\n",
    "    \"poly.fit(x)\\n\",\n",
    "    \"x_poly = poly.transform(x)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# x_poly = poly.fit_transform(x)\\n\",\n",
    "    \"print(x_poly)\"\n",
    "   ]\n",
    "  },\n",
